{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gothic Lockpicking Tool",
  "version": "1.0.0",
  "identifier": "com.tiarinhino.gothic-lockpicking-tool",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Gothic Lockpicking Tool",
        "width": 1060,
        "height": 920,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
